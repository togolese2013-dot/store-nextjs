# ──────────────────────────────────────────────
# REQUIRED — Base de données MySQL (cloud)
# ──────────────────────────────────────────────
DB_HOST=your-mysql-host.railway.app
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# ──────────────────────────────────────────────
# REQUIRED — Cloudinary (stockage des images)
# https://cloudinary.com → Dashboard → API Keys
# ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ──────────────────────────────────────────────
# REQUIRED — Sécurité JWT (changer en prod !)
# ──────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# ──────────────────────────────────────────────
# REQUIRED — Site (URL publique Netlify)
# ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app
NEXT_PUBLIC_SITE_NAME=Togolese Shop

# ──────────────────────────────────────────────
# OPTIONAL — WhatsApp Business
# ──────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=22890000000
