{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "..",
    "baseUrl": "..",
    "paths": {
      "@/lib/*": ["lib/*"]
    }
  },
  "include": ["backend/**/*", "lib/**/*"],
  "exclude": ["node_modules", "backend/dist", "app", "components"]
}
