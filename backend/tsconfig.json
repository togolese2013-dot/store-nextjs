{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "..",
    "baseUrl": "..",
    "paths": {
      "@/lib/*": ["lib/*"],
      "@/backend/*": ["backend/*"]
    }
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS"
    },
    "esm": false,
    "experimentalEsm": false
  },
  "include": ["backend/**/*", "lib/**/*"],
  "exclude": ["node_modules", "backend/dist", "app", "components"]
}
